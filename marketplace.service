[Unit]
Description=Marketplace Python Service
After=network.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/root/marketplace
Environment=PYTHONUNBUFFERED=1
Environment=PORT=5000
ExecStart=/root/marketplace/.venv/bin/python main.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
